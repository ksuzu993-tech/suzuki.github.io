<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="noindex,nofollow" />
<title>Gem システムプロンプト集 — The Library</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,700;1,400;1,500&family=Shippori+Mincho:wght@400;600;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  :root {
    --ink: #1f1814;
    --paper: #f5ecd9;
    --paper-2: #e8dcc1;
    --gold: #c9a449;
    --gold-2: #e8c878;
    --burgundy: #6b1e1a;
    --leather: #4a2818;
    --muted: #8a7a60;
    --shadow: 0 20px 60px rgba(31, 24, 20, 0.4);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: #0f0a06; color: var(--ink); min-height: 100vh; scroll-behavior: smooth; }
  body {
    font-family: "Shippori Mincho", "Cormorant Garamond", serif;
    font-weight: 400; line-height: 1.7;
    position: relative; overflow-x: hidden;
  }

  /* Library Background */
  .library-bg {
    position: fixed; inset: 0; z-index: -2; overflow: hidden;
    background: radial-gradient(ellipse at 50% 30%, #3a2517 0%, #1a0e08 60%, #0a0604 100%);
  }
  .library-bg svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .library-bg::before {
    content: ""; position: absolute; inset: 0;
    background:
      radial-gradient(circle at 20% 25%, rgba(232, 200, 120, 0.18) 0, transparent 25%),
      radial-gradient(circle at 80% 25%, rgba(232, 200, 120, 0.18) 0, transparent 25%),
      radial-gradient(circle at 50% 70%, rgba(201, 164, 73, 0.12) 0, transparent 40%);
    pointer-events: none;
  }
  .library-bg::after {
    content: ""; position: absolute; inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.95 0 0 0 0 0.85 0 0 0 0 0.6 0 0 0 0.04 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
    pointer-events: none; mix-blend-mode: screen;
  }
  .vignette {
    position: fixed; inset: 0; z-index: -1; pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.6) 100%);
  }

  /* Topbar */
  .topbar {
    padding: 16px 32px; display: flex; justify-content: space-between;
    align-items: center; font-family: "JetBrains Mono", monospace;
    font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--gold-2); background: rgba(15, 10, 6, 0.7);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    border-bottom: 1px solid rgba(201, 164, 73, 0.2);
    position: sticky; top: 0; z-index: 10;
  }
  .topbar__left { display: flex; gap: 16px; align-items: center; }
  .topbar__back {
    color: var(--gold-2); text-decoration: none;
    transition: color .2s ease;
  }
  .topbar__back:hover { color: var(--gold); }
  .topbar__right { color: var(--muted); }

  /* Hero */
  .hero {
    padding: 80px 32px 40px; max-width: 1100px; margin: 0 auto;
    text-align: center; color: var(--paper);
  }
  .hero__crest {
    display: inline-block; width: 48px; height: 48px;
    border: 1px solid var(--gold); border-radius: 50%; line-height: 46px;
    color: var(--gold); font-family: "Cormorant Garamond", serif;
    font-style: italic; font-size: 22px; margin-bottom: 24px;
  }
  .hero__kicker {
    font-family: "JetBrains Mono", monospace; font-size: 10px;
    letter-spacing: 0.4em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 20px;
  }
  .hero__title {
    font-family: "Cormorant Garamond", serif; font-weight: 400;
    font-style: italic; font-size: clamp(40px, 7vw, 72px);
    line-height: 1.05; letter-spacing: -0.01em; margin-bottom: 12px;
    color: var(--paper); text-shadow: 0 2px 20px rgba(0,0,0,0.6);
  }
  .hero__title-jp {
    font-family: "Shippori Mincho", serif; font-weight: 600;
    font-size: clamp(18px, 2.4vw, 24px); color: var(--gold-2);
    margin-bottom: 28px; letter-spacing: 0.1em;
  }
  .hero__lead {
    font-family: "Shippori Mincho", serif; font-size: 15px;
    max-width: 600px; margin: 0 auto; color: var(--paper-2); line-height: 1.95;
  }

  /* How to use */
  .howto-wrap { max-width: 1100px; margin: 0 auto; padding: 40px 32px; }
  .howto {
    background: linear-gradient(180deg, rgba(20, 14, 8, 0.85) 0%, rgba(15, 10, 6, 0.85) 100%);
    border: 1px solid rgba(201, 164, 73, 0.3);
    padding: 32px 36px; color: var(--paper-2);
  }
  .howto__title {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 22px; color: var(--gold-2); text-align: center;
    margin-bottom: 8px;
  }
  .howto__title small {
    display: block; font-family: "JetBrains Mono", monospace;
    font-style: normal; font-size: 10px; letter-spacing: 0.3em;
    color: var(--muted); text-transform: uppercase; margin-top: 6px;
  }
  .howto__steps {
    list-style: none; counter-reset: step;
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 16px; margin-top: 28px;
  }
  .howto__steps li {
    counter-increment: step;
    padding: 16px 14px 16px 44px;
    background: rgba(201, 164, 73, 0.08);
    border-left: 2px solid var(--gold);
    font-family: "Shippori Mincho", serif;
    font-size: 13px; line-height: 1.7;
    position: relative; min-height: 100%;
  }
  .howto__steps li::before {
    content: counter(step, decimal-leading-zero);
    position: absolute; left: 14px; top: 14px;
    font-family: "Cormorant Garamond", serif;
    font-style: italic; font-size: 18px;
    color: var(--gold);
  }
  @media (max-width: 720px) {
    .howto__steps { grid-template-columns: 1fr; }
  }

  /* Index nav */
  .index-nav-wrap { max-width: 1100px; margin: 0 auto; padding: 0 32px 40px; }
  .index-nav {
    background: linear-gradient(180deg, rgba(245, 236, 217, 0.97) 0%, rgba(232, 220, 193, 0.97) 100%);
    color: var(--ink); padding: 24px 32px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35), inset 0 0 0 1px rgba(201, 164, 73, 0.5);
    display: flex; flex-wrap: wrap; gap: 12px;
    align-items: center; justify-content: center;
  }
  .index-nav__label {
    font-family: "JetBrains Mono", monospace; font-size: 10px;
    letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--burgundy); margin-right: 8px;
  }
  .index-nav__item {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 14px; text-decoration: none; color: var(--ink);
    padding: 6px 14px; border: 1px solid var(--ink);
    transition: background .2s ease, color .2s ease;
  }
  .index-nav__item:hover {
    background: var(--ink); color: var(--gold-2);
  }
  .index-nav__item span {
    font-family: "JetBrains Mono", monospace; font-style: normal;
    font-size: 10px; color: var(--muted); margin-right: 6px;
    letter-spacing: 0.15em;
  }
  .index-nav__item:hover span { color: var(--gold); }

  /* Prompt card */
  .prompt-section { max-width: 1100px; margin: 0 auto; padding: 40px 32px; }

  .prompt-card {
    background: linear-gradient(180deg, rgba(245, 236, 217, 0.97) 0%, rgba(232, 220, 193, 0.97) 100%);
    color: var(--ink); padding: 0;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35), inset 0 0 0 1px rgba(201, 164, 73, 0.5);
    margin-bottom: 32px;
    position: relative;
    scroll-margin-top: 80px;
  }
  .prompt-card::before {
    content: ""; position: absolute; inset: 6px;
    border: 1px solid rgba(31, 24, 20, 0.15); pointer-events: none;
  }

  .prompt-card__head {
    padding: 32px 40px 24px;
    display: grid; grid-template-columns: 80px 1fr;
    gap: 28px; align-items: center;
    border-bottom: 1px dotted rgba(31, 24, 20, 0.25);
    position: relative;
  }
  .prompt-card__num {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-weight: 300; font-size: 56px; line-height: 1;
    color: var(--burgundy); text-align: center;
  }
  .prompt-card__num small {
    display: block; font-family: "JetBrains Mono", monospace;
    font-style: normal; font-size: 9px; letter-spacing: 0.3em;
    color: var(--muted); margin-top: 6px;
  }
  .prompt-card__tag {
    display: inline-block;
    font-family: "JetBrains Mono", monospace; font-size: 10px;
    letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--burgundy); margin-bottom: 8px;
    padding: 3px 10px; border: 1px solid var(--burgundy);
    background: rgba(107, 30, 26, 0.05);
  }
  .prompt-card__title-en {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 14px; color: var(--muted); margin-bottom: 4px;
    letter-spacing: 0.05em;
  }
  .prompt-card__title {
    font-family: "Shippori Mincho", serif; font-weight: 600;
    font-size: clamp(20px, 2.4vw, 26px); line-height: 1.4;
    color: var(--ink);
  }

  .prompt-card__intro {
    padding: 20px 40px;
    font-size: 14px; color: #5a4a35; line-height: 1.85;
    background: rgba(201, 164, 73, 0.06);
    border-bottom: 1px dotted rgba(31, 24, 20, 0.25);
  }
  .prompt-card__intro strong {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px; letter-spacing: 0.3em;
    text-transform: uppercase; color: var(--gold);
    display: block; margin-bottom: 6px;
    font-weight: 500;
  }

  /* Action bar */
  .prompt-card__actions {
    padding: 16px 40px; display: flex; flex-wrap: wrap;
    gap: 12px; align-items: center; justify-content: space-between;
    background: rgba(31, 24, 20, 0.04);
    border-bottom: 1px dotted rgba(31, 24, 20, 0.25);
  }
  .prompt-card__meta {
    font-family: "JetBrains Mono", monospace; font-size: 10px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted);
  }
  .prompt-card__meta strong {
    color: var(--ink); font-weight: 500;
  }
  .prompt-card__buttons { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 14px; text-decoration: none; cursor: pointer;
    padding: 10px 18px; border: 1px solid var(--ink);
    background: var(--paper); color: var(--ink);
    transition: background .2s ease, color .2s ease;
    white-space: nowrap;
  }
  .btn:hover { background: var(--ink); color: var(--gold-2); }
  .btn--primary { background: var(--ink); color: var(--paper); }
  .btn--primary:hover { background: var(--burgundy); color: var(--gold-2); }
  .btn--copied { background: var(--burgundy) !important; color: var(--gold-2) !important; }
  .btn svg { width: 14px; height: 14px; }

  /* Code block */
  .prompt-card__code-wrap {
    padding: 0; position: relative;
    max-height: 480px; overflow: hidden;
    transition: max-height .4s ease;
  }
  .prompt-card__code-wrap.is-expanded { max-height: 6000px; }
  .prompt-card__code-wrap::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: 0;
    height: 80px; pointer-events: none;
    background: linear-gradient(180deg, transparent 0%, rgba(232, 220, 193, 0.97) 100%);
    transition: opacity .3s ease;
  }
  .prompt-card__code-wrap.is-expanded::after { opacity: 0; }
  .prompt-card__code {
    font-family: "JetBrains Mono", monospace;
    font-size: 12.5px; line-height: 1.75;
    color: var(--ink); padding: 24px 40px;
    background: rgba(255, 250, 240, 0.5);
    white-space: pre-wrap; word-break: break-word;
    margin: 0;
  }

  .prompt-card__expand {
    text-align: center; padding: 16px;
    border-top: 1px dotted rgba(31, 24, 20, 0.25);
    background: rgba(31, 24, 20, 0.04);
  }
  .prompt-card__expand button {
    background: none; border: none;
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 14px; color: var(--burgundy); cursor: pointer;
    letter-spacing: 0.05em;
  }
  .prompt-card__expand button:hover { color: var(--ink); }

  @media (max-width: 720px) {
    .prompt-card__head { grid-template-columns: 56px 1fr; padding: 24px 20px; gap: 16px; }
    .prompt-card__num { font-size: 40px; }
    .prompt-card__intro, .prompt-card__actions { padding-left: 20px; padding-right: 20px; }
    .prompt-card__code { padding-left: 20px; padding-right: 20px; font-size: 11.5px; }
    .prompt-card__actions { flex-direction: column; align-items: stretch; }
    .prompt-card__buttons { justify-content: center; }
  }

  /* Toast */
  .toast {
    position: fixed; bottom: 32px; left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--ink); color: var(--gold-2);
    padding: 14px 28px; font-family: "Shippori Mincho", serif;
    font-size: 14px; border: 1px solid var(--gold);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
    z-index: 1000; opacity: 0;
    transition: opacity .3s ease, transform .3s ease;
    pointer-events: none;
  }
  .toast.is-shown {
    opacity: 1; transform: translateX(-50%) translateY(0);
  }

  /* Footer */
  .footer {
    padding: 48px 32px; text-align: center; color: var(--muted);
    border-top: 1px solid rgba(201, 164, 73, 0.15); margin-top: 40px;
  }
  .footer__crest { display: inline-block; color: var(--gold); font-size: 14px; margin-bottom: 12px; }
  .footer__line {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 16px; color: var(--paper-2); margin-bottom: 8px;
  }
  .footer__sub {
    font-family: "JetBrains Mono", monospace; font-size: 10px;
    letter-spacing: 0.3em; text-transform: uppercase;
  }
  .footer__back {
    display: inline-block; margin-top: 16px;
    color: var(--gold-2); text-decoration: none;
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 14px; padding: 8px 16px;
    border: 1px solid var(--gold);
    transition: background .2s ease;
  }
  .footer__back:hover { background: rgba(201, 164, 73, 0.15); }

  .hero, .howto-wrap, .index-nav-wrap, .prompt-card {
    animation: fadeUp .6s ease both;
  }
  .howto-wrap { animation-delay: .08s; }
  .index-nav-wrap { animation-delay: .16s; }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
</head>
